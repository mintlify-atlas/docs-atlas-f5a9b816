  "keyFeatures": [
    "Interactive 2D grid designer with drag-and-drop bin placement",
    "Real-time 3D preview with multiple render modes (Solid, X-Ray, Blueprint)",
    "Accurate Gridfinity specification geometry with CSG operations",
    "3MF export for direct import to slicers (PrusaSlicer, Cura, Bambu Studio)",
    "Auto-fill and layout optimization tools",
    "Bill of materials with PLA cost calculation",
    "Progressive Web App with offline support",
    "URL sharing for layouts",
    "Configurable printer and baseplate presets",
    "Interior dividers, stacking lips, magnet/screw holes"
  ],
  "publicApiSurface": [
    "useStore - Zustand store with bins, grid, and UI state",
    "GF constants - Gridfinity dimensions and tolerances",
    "GRID_PRESETS - Bambu Lab printer presets (A1, A1 Mini, P1S, X1C, etc.)",
    "BIN_PRESETS - Common bin configurations",
    "LAYOUT_TEMPLATES - Pre-made layouts (IKEA Alex, Electronics Bench, etc.)",
    "generateBinGeometry() - Manifold CSG bin generation",
    "generateBaseplateGeometry() - Manifold CSG baseplate generation",
    "export3MF() - 3MF file packaging and download",
    "useManifold() - WASM initialization hook",
    "useManifoldWorker() - Web Worker interface hook"
  ]
